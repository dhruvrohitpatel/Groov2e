# Gemini audio generation (Lyria).
# Get a key at https://aistudio.google.com/apikey and copy this file to `.env.local`.
VITE_GEMINI_API_KEY=

# Optional: override the music model. Defaults to "lyria-3-clip-preview".
# Accepted values include "lyria-3-clip-preview" (30s) and "lyria-3-pro-preview" (full-length).
# VITE_GEMINI_MUSIC_MODEL=lyria-3-clip-preview

# Optional: chat / tool-calling model for the Genie agent. Defaults to "gemini-2.5-flash".
# Use a reasoning-capable model such as "gemini-2.5-pro" for richer multi-step edits.
# VITE_GEMINI_CHAT_MODEL=gemini-2.5-flash
